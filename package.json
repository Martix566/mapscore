{
  "name": "mapscore",
  "version": "1.0.0",
  "description": "Sports match simulation platform with AI-generated matches",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "cd server && nodemon --exec ts-node src/index.ts",
    "client:dev": "cd client && npm start",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && tsc",
    "start": "node server/dist/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "pg": "^8.10.0",
    "bcrypt": "^5.1.0",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "nodemon": "^3.0.1",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
